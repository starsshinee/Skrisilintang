         <div class="relative"><i data-lucide="lock" class="w-4 h-4 text-navy-400 absolute left-3 top-1/2 -translate-y-1/2"></i> <input type="password" id="login-password" required class="w-full pl-10 pr-4 py-2.5 bg-navy-50 border border-navy-200 rounded-xl text-sm focus:border-navy-600" placeholder="Masukkan password">
         </div>
        </div>
