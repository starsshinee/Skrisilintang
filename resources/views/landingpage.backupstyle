<!doctype html>
<html lang="id" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SIMBAN - BPMP Gorontalo</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <script src="/_sdk/data_sdk.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet">
  <script>
tailwind.config = {
  theme: {
    extend: {
      fontFamily: { jakarta: ['Plus Jakarta Sans', 'sans-serif'] },
      colors: {
        navy: { 50:'#eff4ff',100:'#dae5ff',200:'#bed4ff',300:'#91b8ff',400:'#5d92fc',500:'#366cf9',600:'#1a4bee',700:'#1339db',800:'#0f2fb1',900:'#0c2a8c',950:'#091b55' },
      }
    }
  }
}
</script>
  <style>
html,body{height:100%;margin:0;padding:0;font-family:'Plus Jakarta Sans',sans-serif}
*{box-sizing:border-box}
.app-root{height:100%;width:100%;overflow:auto;scroll-behavior:smooth}
.fade-in{animation:fadeIn .5s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.slide-in{animation:slideIn .4s ease}
@keyframes slideIn{from{opacity:0;transform:translateX(-20px)}to{opacity:1;transform:translateX(0)}}
.card-hover{transition:all .3s ease}
.card-hover:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(9,27,85,.12)}
.carousel-track{display:flex;transition:transform .5s ease}
.nav-link{position:relative}
.nav-link::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:2px;background:#1a4bee;transition:width .3s}
.nav-link:hover::after{width:100%}
.btn-primary{background:linear-gradient(135deg,#1a4bee,#0c2a8c);transition:all .3s}
.btn-primary:hover{background:linear-gradient(135deg,#366cf9,#1339db);transform:translateY(-1px);box-shadow:0 6px 20px rgba(26,75,238,.35)}
.sidebar-item{transition:all .2s}
.sidebar-item:hover,.sidebar-item.active{background:rgba(26,75,238,.1);color:#1a4bee}
.stat-card{background:linear-gradient(135deg,var(--c1),var(--c2));color:#fff;border-radius:16px;padding:24px}
.toast{position:fixed;top:20px;right:20px;z-index:9999;padding:14px 24px;border-radius:12px;color:#fff;font-weight:600;animation:fadeIn .3s;max-width:360px}
.toast-success{background:#059669}
.toast-error{background:#dc2626}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1000;display:flex;align-items:center;justify-content:center}
.modal-box{background:#fff;border-radius:16px;padding:32px;max-width:480px;width:90%;animation:fadeIn .3s}
input:focus,select:focus,textarea:focus{outline:none;ring:2px;border-color:#1a4bee;box-shadow:0 0 0 3px rgba(26,75,238,.15)}
::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:#f1f5f9}::-webkit-scrollbar-thumb{background:#94a3b8;border-radius:3px}
</style>
  <style>body { box-sizing: border-box; }</style>
 </head>
 <body class="h-full">
  <div class="app-root bg-white" id="app"><!-- ==================== LANDING PAGE ==================== -->
   <div id="page-landing"><!-- Navbar -->
    <nav id="navbar" class="fixed top-0 left-0 w-full z-50 bg-white/95 backdrop-blur border-b border-navy-100 transition-all">
     <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
      <div class="flex items-center gap-3">
       <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-navy-600 to-navy-900 flex items-center justify-center"><span class="text-white font-extrabold text-sm">SB</span>
       </div>
       <div>
        <div id="nav-title" class="font-bold text-navy-900 text-sm leading-tight">
         SIMBAN
        </div>
        <div class="text-[10px] text-navy-500 leading-tight">
         BPMP Gorontalo
        </div>
       </div>
      </div>
      <div class="hidden md:flex items-center gap-6 text-sm font-medium text-navy-700"><a href="#hero" class="nav-link" onclick="scrollToSection('hero')">Beranda</a> <a href="#fitur" class="nav-link" onclick="scrollToSection('fitur')">Fitur</a> <a href="#statistik" class="nav-link" onclick="scrollToSection('statistik')">Statistik</a> <a href="#fasilitas" class="nav-link" onclick="scrollToSection('fasilitas')">Fasilitas</a> <a href="#kontak" class="nav-link" onclick="scrollToSection('kontak')">Kontak</a>
      </div>
      <div class="flex items-center gap-2"><button onclick="showPage('login')" class="px-4 py-2 text-sm font-semibold text-navy-700 hover:text-navy-900 rounded-lg hover:bg-navy-50 transition">Masuk</button> <button onclick="showPage('register')" class="btn-primary px-4 py-2 text-sm font-semibold text-white rounded-lg">Daftar</button> <button class="md:hidden p-2 text-navy-700" onclick="toggleMobileMenu()"><i data-lucide="menu" class="w-5 h-5"></i></button>
      </div>
     </div><!-- Mobile menu -->
     <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-navy-100 px-4 pb-4">
      <div class="flex flex-col gap-2 pt-2 text-sm font-medium text-navy-700"><a href="#hero" onclick="scrollToSection('hero');toggleMobileMenu()" class="py-2 px-3 rounded-lg hover:bg-navy-50">Beranda</a> <a href="#fitur" onclick="scrollToSection('fitur');toggleMobileMenu()" class="py-2 px-3 rounded-lg hover:bg-navy-50">Fitur</a> <a href="#statistik" onclick="scrollToSection('statistik');toggleMobileMenu()" class="py-2 px-3 rounded-lg hover:bg-navy-50">Statistik</a> <a href="#fasilitas" onclick="scrollToSection('fasilitas');toggleMobileMenu()" class="py-2 px-3 rounded-lg hover:bg-navy-50">Fasilitas</a> <a href="#kontak" onclick="scrollToSection('kontak');toggleMobileMenu()" class="py-2 px-3 rounded-lg hover:bg-navy-50">Kontak</a>
      </div>
     </div>
    </nav><!-- Hero Section -->
    <section id="hero" class="pt-24 pb-16 px-4 sm:px-6 lg:px-8 bg-gradient-to-br from-navy-50 via-white to-blue-50 relative overflow-hidden">
     <div class="absolute top-0 right-0 w-96 h-96 bg-navy-200/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
     <div class="absolute bottom-0 left-0 w-72 h-72 bg-blue-200/20 rounded-full blur-3xl translate-y-1/2 -translate-x-1/3"></div>
     <div class="max-w-7xl mx-auto relative">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
       <div class="fade-in">
        <div class="inline-flex items-center gap-2 bg-navy-100 text-navy-700 text-xs font-semibold px-3 py-1.5 rounded-full mb-6"><i data-lucide="shield-check" class="w-3.5 h-3.5"></i> Sistem Terintegrasi
        </div>
        <h1 id="hero-title" class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-navy-950 leading-tight mb-6">Sistem Informasi<br><span class="text-transparent bg-clip-text bg-gradient-to-r from-navy-600 to-blue-500">Manajemen BMN</span></h1>
        <p id="hero-subtitle" class="text-lg text-navy-600 mb-8 max-w-lg leading-relaxed">Platform digital pencatatan dan monitoring Barang Milik Negara pada Badan Penjaminan Mutu Pendidikan Provinsi Gorontalo secara transparan, akuntabel, dan real-time.</p>
        <div class="flex flex-wrap gap-3"><button onclick="showPage('register')" class="btn-primary px-6 py-3 text-white font-semibold rounded-xl flex items-center gap-2"> Mulai Sekarang <i data-lucide="arrow-right" class="w-4 h-4"></i> </button> <button onclick="scrollToSection('fitur')" class="px-6 py-3 bg-white border-2 border-navy-200 text-navy-700 font-semibold rounded-xl hover:bg-navy-50 transition flex items-center gap-2"> <i data-lucide="play-circle" class="w-4 h-4"></i> Pelajari Fitur </button>
        </div>
        <div class="flex items-center gap-6 mt-10 text-sm text-navy-500">
         <div class="flex items-center gap-2">
          <i data-lucide="check-circle" class="w-4 h-4 text-green-500"></i>Gratis
         </div>
         <div class="flex items-center gap-2">
          <i data-lucide="check-circle" class="w-4 h-4 text-green-500"></i>Aman
         </div>
         <div class="flex items-center gap-2">
          <i data-lucide="check-circle" class="w-4 h-4 text-green-500"></i>Real-time
         </div>
        </div>
       </div>
       <div class="fade-in hidden lg:block">
        <div class="relative">
         <div class="bg-white rounded-2xl shadow-xl p-6 border border-navy-100">
          <div class="flex items-center gap-2 mb-4">
           <div class="w-3 h-3 rounded-full bg-red-400"></div>
           <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
           <div class="w-3 h-3 rounded-full bg-green-400"></div><span class="text-xs text-navy-400 ml-2">Dashboard SIMBAN</span>
          </div>
          <div class="grid grid-cols-3 gap-3 mb-4">
           <div class="bg-gradient-to-br from-navy-500 to-navy-700 rounded-xl p-3 text-white text-center">
            <div class="text-2xl font-bold">
             1,248
            </div>
            <div class="text-[10px] opacity-80">
             Total Aset
            </div>
           </div>
           <div class="bg-gradient-to-br from-blue-500 to-blue-700 rounded-xl p-3 text-white text-center">
            <div class="text-2xl font-bold">
             856
            </div>
            <div class="text-[10px] opacity-80">
             Persediaan
            </div>
           </div>
           <div class="bg-gradient-to-br from-sky-500 to-sky-700 rounded-xl p-3 text-white text-center">
            <div class="text-2xl font-bold">
             392
            </div>
            <div class="text-[10px] opacity-80">
             Sarana
            </div>
           </div>
          </div>
          <div class="space-y-2">
           <div class="flex items-center justify-between bg-navy-50 rounded-lg p-2.5 text-xs">
            <div class="flex items-center gap-2">
             <div class="w-2 h-2 rounded-full bg-green-500"></div><span class="text-navy-700 font-medium">Laptop Lenovo ThinkPad</span>
            </div><span class="text-navy-500">Baik</span>
           </div>
           <div class="flex items-center justify-between bg-navy-50 rounded-lg p-2.5 text-xs">
            <div class="flex items-center gap-2">
             <div class="w-2 h-2 rounded-full bg-green-500"></div><span class="text-navy-700 font-medium">Proyektor Epson EB-X51</span>
            </div><span class="text-navy-500">Baik</span>
           </div>
           <div class="flex items-center justify-between bg-navy-50 rounded-lg p-2.5 text-xs">
            <div class="flex items-center gap-2">
             <div class="w-2 h-2 rounded-full bg-yellow-500"></div><span class="text-navy-700 font-medium">AC Daikin 2 PK</span>
            </div><span class="text-navy-500">Pemeliharaan</span>
           </div>
          </div>
         </div>
         <div class="absolute -bottom-4 -right-4 bg-green-500 text-white rounded-xl px-4 py-2 text-xs font-bold shadow-lg flex items-center gap-2"><i data-lucide="trending-up" class="w-4 h-4"></i> +12% Efisiensi
         </div>
        </div>
       </div>
      </div>
     </div>
    </section><!-- Fitur Section -->
    <section id="fitur" class="py-20 px-4 sm:px-6 lg:px-8 bg-white">
     <div class="max-w-7xl mx-auto">
      <div class="text-center mb-14">
       <div class="inline-flex items-center gap-2 bg-navy-100 text-navy-700 text-xs font-semibold px-3 py-1.5 rounded-full mb-4"><i data-lucide="zap" class="w-3.5 h-3.5"></i> Fitur Unggulan
       </div>
       <h2 class="text-3xl sm:text-4xl font-extrabold text-navy-950 mb-4">Kelola BMN dengan Mudah</h2>
       <p class="text-navy-500 max-w-2xl mx-auto">Fitur lengkap untuk pencatatan, monitoring, dan pelaporan Barang Milik Negara di lingkungan BPMP Gorontalo.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
       <div class="card-hover bg-white rounded-2xl p-6 border border-navy-100 group">
        <div class="w-12 h-12 rounded-xl bg-navy-100 flex items-center justify-center mb-4 group-hover:bg-navy-600 transition">
         <i data-lucide="package" class="w-6 h-6 text-navy-600 group-hover:text-white transition"></i>
        </div>
        <h3 class="font-bold text-navy-900 mb-2">Manajemen Persediaan</h3>
        <p class="text-sm text-navy-500">Pencatatan stok barang habis pakai, ATK, dan bahan operasional dengan tracking real-time.</p>
       </div>
       <div class="card-hover bg-white rounded-2xl p-6 border border-navy-100 group">
        <div class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center mb-4 group-hover:bg-blue-600 transition">
         <i data-lucide="building" class="w-6 h-6 text-blue-600 group-hover:text-white transition"></i>
        </div>
        <h3 class="font-bold text-navy-900 mb-2">Sarana &amp; Prasarana</h3>
        <p class="text-sm text-navy-500">Monitoring kondisi gedung, ruangan, dan fasilitas pendukung kegiatan operasional.</p>
       </div>
       <div class="card-hover bg-white rounded-2xl p-6 border border-navy-100 group">
        <div class="w-12 h-12 rounded-xl bg-sky-100 flex items-center justify-center mb-4 group-hover:bg-sky-600 transition">
         <i data-lucide="landmark" class="w-6 h-6 text-sky-600 group-hover:text-white transition"></i>
        </div>
        <h3 class="font-bold text-navy-900 mb-2">Aset Tetap</h3>
        <p class="text-sm text-navy-500">Pengelolaan aset tetap meliputi tanah, gedung, kendaraan, dan peralatan mesin.</p>
       </div>
       <div class="card-hover bg-white rounded-2xl p-6 border border-navy-100 group">
        <div class="w-12 h-12 rounded-xl bg-emerald-100 flex items-center justify-center mb-4 group-hover:bg-emerald-600 transition">
         <i data-lucide="file-bar-chart" class="w-6 h-6 text-emerald-600 group-hover:text-white transition"></i>
        </div>
        <h3 class="font-bold text-navy-900 mb-2">Laporan Otomatis</h3>
        <p class="text-sm text-navy-500">Generate laporan BMN semesteran dan tahunan sesuai format Kementerian Keuangan.</p>
       </div>
       <div class="card-hover bg-white rounded-2xl p-6 border border-navy-100 group">
        <div class="w-12 h-12 rounded-xl bg-amber-100 flex items-center justify-center mb-4 group-hover:bg-amber-600 transition">
         <i data-lucide="scan-line" class="w-6 h-6 text-amber-600 group-hover:text-white transition"></i>
        </div>
        <h3 class="font-bold text-navy-900 mb-2">Peminjaman Aset</h3>
        <p class="text-sm text-navy-500">Sistem peminjaman dan pengembalian barang dengan approval workflow bertingkat.</p>
       </div>
       <div class="card-hover bg-white rounded-2xl p-6 border border-navy-100 group">
        <div class="w-12 h-12 rounded-xl bg-rose-100 flex items-center justify-center mb-4 group-hover:bg-rose-600 transition">
         <i data-lucide="shield" class="w-6 h-6 text-rose-600 group-hover:text-white transition"></i>
        </div>
        <h3 class="font-bold text-navy-900 mb-2">Multi-Role Access</h3>
        <p class="text-sm text-navy-500">Kontrol akses berbasis peran: Superadmin, Kepala BPMP, Kasubag, Admin, dan Pegawai.</p>
       </div>
      </div>
     </div>
    </section><!-- Statistik Section -->
    <section id="statistik" class="py-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-br from-navy-900 via-navy-800 to-navy-950 relative overflow-hidden">
     <div class="absolute inset-0 opacity-10" style="background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2260%22 height=%2260%22><circle cx=%2230%22 cy=%2230%22 r=%221.5%22 fill=%22white%22/></svg>');background-size:60px 60px"></div>
     <div class="max-w-7xl mx-auto relative">
      <div class="text-center mb-14">
       <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">Statistik BMN BPMP Gorontalo</h2>
       <p class="text-navy-300 max-w-2xl mx-auto">Data pengelolaan Barang Milik Negara yang dikelola secara transparan dan akuntabel.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
       <div class="stat-card" style="--c1:#1a4bee;--c2:#0c2a8c">
        <div class="flex items-center justify-between mb-3"><i data-lucide="box" class="w-8 h-8 opacity-80"></i> <span class="text-xs bg-white/20 rounded-full px-2 py-0.5">+8%</span>
        </div>
        <div class="text-3xl font-extrabold">
         1,248
        </div>
        <div class="text-sm opacity-80 mt-1">
         Total Aset BMN
        </div>
       </div>
       <div class="stat-card" style="--c1:#0284c7;--c2:#0369a1">
        <div class="flex items-center justify-between mb-3"><i data-lucide="package" class="w-8 h-8 opacity-80"></i> <span class="text-xs bg-white/20 rounded-full px-2 py-0.5">+15%</span>
        </div>
        <div class="text-3xl font-extrabold">
         856
        </div>
        <div class="text-sm opacity-80 mt-1">
         Persediaan
        </div>
       </div>
       <div class="stat-card" style="--c1:#059669;--c2:#047857">
        <div class="flex items-center justify-between mb-3"><i data-lucide="building-2" class="w-8 h-8 opacity-80"></i> <span class="text-xs bg-white/20 rounded-full px-2 py-0.5">+5%</span>
        </div>
        <div class="text-3xl font-extrabold">
         Rp 24.5M
        </div>
        <div class="text-sm opacity-80 mt-1">
         Nilai Aset Tetap
        </div>
       </div>
       <div class="stat-card" style="--c1:#7c3aed;--c2:#6d28d9">
        <div class="flex items-center justify-between mb-3"><i data-lucide="users" class="w-8 h-8 opacity-80"></i> <span class="text-xs bg-white/20 rounded-full px-2 py-0.5">Active</span>
        </div>
        <div class="text-3xl font-extrabold">
         47
        </div>
        <div class="text-sm opacity-80 mt-1">
         Pengguna Aktif
        </div>
       </div>
      </div>
      <div class="grid sm:grid-cols-3 gap-6 mt-6">
       <div class="bg-white/10 backdrop-blur rounded-2xl p-6 text-center border border-white/10">
        <div class="text-2xl font-bold text-white">
         392
        </div>
        <div class="text-sm text-navy-300 mt-1">
         Sarana Prasarana
        </div>
        <div class="mt-3 h-2 bg-white/10 rounded-full overflow-hidden">
         <div class="h-full bg-blue-400 rounded-full" style="width:78%"></div>
        </div>
        <div class="text-xs text-navy-400 mt-1">
         78% Kondisi Baik
        </div>
       </div>
       <div class="bg-white/10 backdrop-blur rounded-2xl p-6 text-center border border-white/10">
        <div class="text-2xl font-bold text-white">
         156
        </div>
        <div class="text-sm text-navy-300 mt-1">
         Peminjaman Aktif
        </div>
        <div class="mt-3 h-2 bg-white/10 rounded-full overflow-hidden">
         <div class="h-full bg-green-400 rounded-full" style="width:92%"></div>
        </div>
        <div class="text-xs text-navy-400 mt-1">
         92% Tepat Waktu
        </div>
       </div>
       <div class="bg-white/10 backdrop-blur rounded-2xl p-6 text-center border border-white/10">
        <div class="text-2xl font-bold text-white">
         24
        </div>
        <div class="text-sm text-navy-300 mt-1">
         Laporan Dibuat
        </div>
        <div class="mt-3 h-2 bg-white/10 rounded-full overflow-hidden">
         <div class="h-full bg-amber-400 rounded-full" style="width:100%"></div>
        </div>
        <div class="text-xs text-navy-400 mt-1">
         100% Selesai
        </div>
       </div>
      </div>
     </div>
    </section><!-- Fasilitas Carousel Section -->
    <section id="fasilitas" class="py-20 px-4 sm:px-6 lg:px-8 bg-navy-50">
     <div class="max-w-7xl mx-auto">
      <div class="text-center mb-14">
       <div class="inline-flex items-center gap-2 bg-navy-100 text-navy-700 text-xs font-semibold px-3 py-1.5 rounded-full mb-4"><i data-lucide="image" class="w-3.5 h-3.5"></i> Fasilitas
       </div>
       <h2 class="text-3xl sm:text-4xl font-extrabold text-navy-950 mb-4">Fasilitas BPMP Gorontalo</h2>
       <p class="text-navy-500 max-w-2xl mx-auto">Fasilitas yang tersedia untuk disewakan bagi keperluan kegiatan pendidikan dan pelatihan.</p>
      </div>
      <div class="relative">
       <div class="overflow-hidden rounded-2xl">
        <div class="carousel-track" id="carousel-track"><!-- Slide 1 -->
         <div class="min-w-full flex flex-col lg:flex-row gap-6 px-1">
          <div class="lg:w-1/2 bg-gradient-to-br from-navy-600 to-navy-800 rounded-2xl p-8 flex flex-col justify-center items-center min-h-[320px]"><i data-lucide="presentation" class="w-20 h-20 text-white/80 mb-4"></i> <span class="text-white/60 text-sm">Aula Utama BPMP Gorontalo</span>
          </div>
          <div class="lg:w-1/2 bg-white rounded-2xl p-8 border border-navy-100">
           <div class="flex items-center gap-2 mb-3"><span class="bg-green-100 text-green-700 text-xs font-bold px-2.5 py-1 rounded-full">Tersedia</span> <span class="bg-navy-100 text-navy-600 text-xs font-bold px-2.5 py-1 rounded-full">Kapasitas 200 Orang</span>
           </div>
           <h3 class="text-2xl font-bold text-navy-900 mb-3">Aula Utama</h3>
           <p class="text-navy-500 text-sm mb-4 leading-relaxed">Aula serbaguna berkapasitas 200 orang dilengkapi sound system, proyektor, AC sentral, panggung, dan area parkir luas. Cocok untuk seminar, workshop, dan acara resmi.</p>
           <div class="bg-navy-50 rounded-xl p-4 mb-4">
            <div class="text-xs text-navy-500 mb-1">
             Tarif Sewa
            </div>
            <div class="text-2xl font-extrabold text-navy-900">
             Rp 3.500.000 <span class="text-sm font-normal text-navy-400">/ hari</span>
            </div>
           </div>
