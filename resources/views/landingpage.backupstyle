   <div id="page-register" class="hidden">
    <div class="min-h-full bg-gradient-to-br from-navy-50 via-white to-blue-50 flex items-center justify-center px-4 py-12" style="min-height:100%">
     <div class="w-full max-w-md">
      <div class="text-center mb-8">
       <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-navy-600 to-navy-900 flex items-center justify-center mx-auto mb-4">
        <span class="text-white font-extrabold text-lg">SB</span>
       </div>
       <h1 class="text-2xl font-extrabold text-navy-950">Daftar Akun SIMBAN</h1>
       <p class="text-sm text-navy-500 mt-1">Isi data diri untuk membuat akun</p>
      </div>
      <div class="bg-white rounded-2xl shadow-xl p-8 border border-navy-100">
       <form id="register-form" onsubmit="handleRegister(event)">
        <div class="mb-4"><label for="reg-fullname" class="block text-sm font-semibold text-navy-700 mb-1.5">Nama Lengkap</label> <input type="text" id="reg-fullname" required class="w-full px-4 py-2.5 bg-navy-50 border border-navy-200 rounded-xl text-sm" placeholder="Nama lengkap">
        </div>
        <div class="mb-4"><label for="reg-nip" class="block text-sm font-semibold text-navy-700 mb-1.5">NIP</label> <input type="text" id="reg-nip" required class="w-full px-4 py-2.5 bg-navy-50 border border-navy-200 rounded-xl text-sm" placeholder="Nomor Induk Pegawai">
        </div>
        <div class="mb-4"><label for="reg-email" class="block text-sm font-semibold text-navy-700 mb-1.5">Email</label> <input type="email" id="reg-email" required class="w-full px-4 py-2.5 bg-navy-50 border border-navy-200 rounded-xl text-sm" placeholder="email@kemdikbud.go.id">
        </div>
        <div class="mb-4"><label for="reg-role" class="block text-sm font-semibold text-navy-700 mb-1.5">Jabatan / Role</label> <select id="reg-role" required class="w-full px-4 py-2.5 bg-navy-50 border border-navy-200 rounded-xl text-sm"> <option value="">Pilih jabatan</option> <option value="pegawai">Pegawai</option> <option value="admin_persediaan">Admin Persediaan</option> <option value="admin_sarpras">Admin Sarana Prasarana</option> <option value="admin_aset">Admin Aset Tetap</option> <option value="kasubag">Kasubag</option> <option value="kepala">Kepala BPMP</option> </select>
        </div>
        <div class="mb-4"><label for="reg-username" class="block text-sm font-semibold text-navy-700 mb-1.5">Username</label> <input type="text" id="reg-username" required class="w-full px-4 py-2.5 bg-navy-50 border border-navy-200 rounded-xl text-sm" placeholder="Buat username">
        </div>
        <div class="mb-6"><label for="reg-password" class="block text-sm font-semibold text-navy-700 mb-1.5">Password</label> <input type="password" id="reg-password" required minlength="6" class="w-full px-4 py-2.5 bg-navy-50 border border-navy-200 rounded-xl text-sm" placeholder="Minimal 6 karakter">
        </div>
        <div id="register-error" class="hidden mb-4 bg-red-50 text-red-600 text-sm rounded-xl p-3 flex items-center gap-2"><i data-lucide="alert-circle" class="w-4 h-4"></i><span></span>
        </div>
        <div id="register-success" class="hidden mb-4 bg-green-50 text-green-600 text-sm rounded-xl p-3 flex items-center gap-2"><i data-lucide="check-circle" class="w-4 h-4"></i><span></span>
        </div><button type="submit" id="register-btn" class="btn-primary w-full py-3 text-white font-semibold rounded-xl flex items-center justify-center gap-2"> <span>Daftar</span> </button>
       </form>
       <div class="mt-6 text-center text-sm text-navy-500">
        Sudah punya akun? <button onclick="showPage('login')" class="text-navy-700 font-semibold hover:underline">Masuk</button>
       </div>
      </div><button onclick="showPage('landing')" class="mt-6 flex items-center gap-2 text-sm text-navy-500 hover:text-navy-700 mx-auto transition"> <i data-lucide="arrow-left" class="w-4 h-4"></i> Kembali ke Beranda </button>
     </div>
    </div>
   </div><!-- ==================== DASHBOARD (all roles) ==================== -->
   <div id="page-dashboard" class="hidden">
    <div class="flex" style="height:100%"><!-- Sidebar -->
     <aside id="sidebar" class="w-64 bg-white border-r border-navy-100 flex-shrink-0 flex flex-col overflow-auto hidden lg:flex">
      <div class="p-5 border-b border-navy-100">
       <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-navy-600 to-navy-900 flex items-center justify-center">
         <span class="text-white font-extrabold text-sm">SB</span>
        </div>
        <div>
         <div class="font-bold text-navy-900 text-sm">
          SIMBAN
         </div>
         <div class="text-[10px] text-navy-500">
          BPMP Gorontalo
         </div>
        </div>
       </div>
      </div>
      <nav class="flex-1 p-3 space-y-1" id="sidebar-nav"></nav>
      <div class="p-4 border-t border-navy-100"><button onclick="handleLogout()" class="sidebar-item w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-red-600 hover:bg-red-50"> <i data-lucide="log-out" class="w-4 h-4"></i> Keluar </button>
      </div>
     </aside><!-- Main -->
     <div class="flex-1 flex flex-col overflow-auto bg-navy-50/50"><!-- Top bar -->
      <header class="bg-white border-b border-navy-100 px-4 sm:px-6 py-3 flex items-center justify-between flex-shrink-0">
       <div class="flex items-center gap-3"><button onclick="toggleSidebar()" class="lg:hidden p-2 text-navy-700 hover:bg-navy-100 rounded-lg"><i data-lucide="menu" class="w-5 h-5"></i></button>
        <div>
         <h2 class="font-bold text-navy-900 text-sm" id="topbar-title">Dashboard</h2>
         <p class="text-xs text-navy-500" id="topbar-role">-</p>
        </div>
       </div>
       <div class="flex items-center gap-3"><button class="relative p-2 text-navy-500 hover:bg-navy-100 rounded-lg"> <i data-lucide="bell" class="w-5 h-5"></i> <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full"></span> </button>
        <div class="flex items-center gap-2">
         <div class="w-8 h-8 rounded-full bg-gradient-to-br from-navy-500 to-navy-700 flex items-center justify-center text-white text-xs font-bold" id="user-avatar">
          U
         </div><span class="text-sm font-medium text-navy-700 hidden sm:block" id="user-display-name">User</span>
        </div>
       </div>
      </header><!-- Content -->
      <main class="flex-1 p-4 sm:p-6 overflow-auto" id="main-content"></main>
     </div>
    </div><!-- Mobile sidebar overlay -->
    <div id="sidebar-overlay" class="hidden fixed inset-0 bg-black/40 z-40 lg:hidden" onclick="toggleSidebar()"></div>
    <div id="sidebar-mobile" class="hidden fixed left-0 top-0 bottom-0 w-64 bg-white z-50 flex flex-col overflow-auto lg:hidden shadow-xl">
     <div class="p-5 border-b border-navy-100 flex items-center justify-between">
      <div class="flex items-center gap-3">
       <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-navy-600 to-navy-900 flex items-center justify-center">
        <span class="text-white font-extrabold text-sm">SB</span>
       </div>
       <div>
        <div class="font-bold text-navy-900 text-sm">
         SIMBAN
        </div>
       </div>
      </div><button onclick="toggleSidebar()" class="p-1 text-navy-500"><i data-lucide="x" class="w-5 h-5"></i></button>
     </div>
     <nav class="flex-1 p-3 space-y-1" id="sidebar-nav-mobile"></nav>
     <div class="p-4 border-t border-navy-100"><button onclick="handleLogout()" class="sidebar-item w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-red-600 hover:bg-red-50"> <i data-lucide="log-out" class="w-4 h-4"></i> Keluar </button>
     </div>
    </div>
   </div><!-- Toast container -->
   <div id="toast-container"></div>
  </div><!-- end app -->
  <script>
// ====================== STATE ======================
let currentPage = 'landing';
let currentUser = null;
let currentDashSection = 'overview';
let registeredUsers = [];
let carouselIndex = 0;
const carouselTotal = 4;

// Role labels
const roleLabels = {
  superadmin: 'Super Admin',
  kepala: 'Kepala BPMP',
  kasubag: 'Kasubag',
  admin_persediaan: 'Admin Persediaan',
  admin_sarpras: 'Admin Sarana Prasarana',
  admin_aset: 'Admin Aset Tetap',
  pegawai: 'Pegawai'
};

// Demo accounts
const demoAccounts = {
  superadmin:{ username:'superadmin', fullname:'Dr. Ahmad Rizal, M.Pd', role:'superadmin', nip:'198501012010011001' },
  kepala:{ username:'kepala', fullname:'Prof. Nurdin Ismail, Ph.D', role:'kepala', nip:'197201012000011001' },
  kasubag:{ username:'kasubag', fullname:'Siti Rahmawati, S.E', role:'kasubag', nip:'198003012005012001' },
  admin_persediaan:{ username:'admin_persediaan', fullname:'Irwan Daud, S.Kom', role:'admin_persediaan', nip:'199001012015011001' },
  admin_sarpras:{ username:'admin_sarpras', fullname:'Fadel Mohamad, S.T', role:'admin_sarpras', nip:'199105012016011001' },
  admin_aset:{ username:'admin_aset', fullname:'Rina Gobel, S.E', role:'admin_aset', nip:'198807012014012001' },
  pegawai:{ username:'pegawai', fullname:'Hendra Poluakan, S.Pd', role:'pegawai', nip:'199201012018011001' }
};

// ====================== NAVIGATION ======================
function showPage(page) {
  document.querySelectorAll('[id^="page-"]').forEach(el => el.classList.add('hidden'));
  const target = document.getElementById('page-' + page);
  if (target) { target.classList.remove('hidden'); }
  currentPage = page;
  if (page === 'landing') {
    document.getElementById('navbar').classList.remove('hidden');
    window.scrollTo(0, 0);
  } else {
    document.getElementById('navbar').classList.add('hidden');
  }
  if (page === 'dashboard') renderDashboard();
  lucide.createIcons();
}

function scrollToSection(id) {
  const el = document.getElementById(id);
  if (el) el.scrollIntoView({ behavior: 'smooth' });
}

function toggleMobileMenu() {
  document.getElementById('mobile-menu').classList.toggle('hidden');
}

// ====================== CAROUSEL ======================
function initCarousel() {
  const dotsC = document.getElementById('carousel-dots');
  dotsC.innerHTML = '';
  for (let i = 0; i < carouselTotal; i++) {
    const d = document.createElement('button');
    d.className = `w-2.5 h-2.5 rounded-full transition ${i === 0 ? 'bg-navy-600 w-6' : 'bg-navy-300'}`;
    d.onclick = () => { carouselIndex = i; updateCarousel(); };
    dotsC.appendChild(d);
  }
}
function moveCarousel(dir) {
  carouselIndex = (carouselIndex + dir + carouselTotal) % carouselTotal;
  updateCarousel();
}
function updateCarousel() {
  const track = document.getElementById('carousel-track');
  track.style.transform = `translateX(-${carouselIndex * 100}%)`;
  const dots = document.getElementById('carousel-dots').children;
  for (let i = 0; i < dots.length; i++) {
    dots[i].className = `h-2.5 rounded-full transition ${i === carouselIndex ? 'bg-navy-600 w-6' : 'bg-navy-300 w-2.5'}`;
  }
}
setInterval(() => { moveCarousel(1); }, 5000);

// ====================== AUTH ======================
function handleLogin(e) {
  e.preventDefault();
  const u = document.getElementById('login-username').value.trim();
  const p = document.getElementById('login-password').value;
  const errEl = document.getElementById('login-error');

  // Check demo accounts (password: demo123)
  const demoKey = Object.keys(demoAccounts).find(k => demoAccounts[k].username === u);
  if (demoKey && p === 'demo123') {
    currentUser = { ...demoAccounts[demoKey] };
    showPage('dashboard');
    showToast('Selamat datang, ' + currentUser.fullname + '!', 'success');
    return;
  }

  // Check registered users
  const found = registeredUsers.find(r => r.username === u);
  if (found && found.password === p) {
    currentUser = { ...found };
    showPage('dashboard');
    showToast('Selamat datang, ' + currentUser.fullname + '!', 'success');
    return;
  }

  errEl.classList.remove('hidden');
  errEl.querySelector('span').textContent = 'Username atau password salah. Gunakan demo123 untuk akun demo.';
}

function demoLogin(roleKey) {
  currentUser = { ...demoAccounts[roleKey] };
  showPage('dashboard');
  showToast('Demo login sebagai ' + roleLabels[roleKey], 'success');
}

async function handleRegister(e) {
  e.preventDefault();
  const errEl = document.getElementById('register-error');
  const sucEl = document.getElementById('register-success');
  errEl.classList.add('hidden');
  sucEl.classList.add('hidden');

  const data = {
    type: 'user',
    fullname: document.getElementById('reg-fullname').value.trim(),
    nip: document.getElementById('reg-nip').value.trim(),
    email: document.getElementById('reg-email').value.trim(),
    role: document.getElementById('reg-role').value,
    username: document.getElementById('reg-username').value.trim(),
    password: document.getElementById('reg-password').value,
    created_at: new Date().toISOString()
  };

  if (!data.role) {
    errEl.classList.remove('hidden');
    errEl.querySelector('span').textContent = 'Pilih jabatan terlebih dahulu.';
    return;
  }

  // Check duplicate
  if (registeredUsers.some(u => u.username === data.username) || Object.values(demoAccounts).some(d => d.username === data.username)) {
    errEl.classList.remove('hidden');
    errEl.querySelector('span').textContent = 'Username sudah digunakan.';
    return;
  }

  const btn = document.getElementById('register-btn');
  btn.disabled = true;
  btn.innerHTML = '<span class="animate-spin w-4 h-4 border-2 border-white border-t-transparent rounded-full"></span> Mendaftar...';

  if (registeredUsers.length >= 999) {
    errEl.classList.remove('hidden');
    errEl.querySelector('span').textContent = 'Batas maksimum pengguna telah tercapai.';
    btn.disabled = false;
    btn.innerHTML = '<span>Daftar</span>';
    return;
  }

  const result = await window.dataSdk.create(data);
  btn.disabled = false;
  btn.innerHTML = '<span>Daftar</span>';

  if (result.isOk) {
    registeredUsers.push({ ...data });
    sucEl.classList.remove('hidden');
    sucEl.querySelector('span').textContent = 'Registrasi berhasil! Silakan login.';
    document.getElementById('register-form').reset();
    setTimeout(() => showPage('login'), 2000);
  } else {
    errEl.classList.remove('hidden');
    errEl.querySelector('span').textContent = 'Gagal mendaftar. Coba lagi.';
  }
}

function handleLogout() {
  currentUser = null;
  showPage('landing');
  showToast('Berhasil keluar dari sistem.', 'success');
}

// ====================== TOAST ======================
function showToast(msg, type = 'success') {
  const t = document.createElement('div');
  t.className = `toast toast-${type}`;
  t.textContent = msg;
  document.getElementById('toast-container').appendChild(t);
  setTimeout(() => t.remove(), 3500);
}

// ====================== SIDEBAR ======================
function toggleSidebar() {
  document.getElementById('sidebar-overlay').classList.toggle('hidden');
  document.getElementById('sidebar-mobile').classList.toggle('hidden');
}

function getSidebarItems(role) {
  const common = [{ id:'overview', icon:'layout-dashboard', label:'Dashboard' }];
  const items = {
    superadmin: [...common,
      { id:'users', icon:'users', label:'Manajemen Pengguna' },
      { id:'persediaan', icon:'package', label:'Persediaan' },
      { id:'sarpras', icon:'building', label:'Sarana Prasarana' },
      { id:'aset', icon:'landmark', label:'Aset Tetap' },
      { id:'peminjaman', icon:'scan-line', label:'Peminjaman' },
      { id:'laporan', icon:'file-bar-chart', label:'Laporan' },
      { id:'settings', icon:'settings', label:'Pengaturan' }
    ],
    kepala: [...common,
      { id:'persediaan', icon:'package', label:'Persediaan' },
      { id:'sarpras', icon:'building', label:'Sarana Prasarana' },
      { id:'aset', icon:'landmark', label:'Aset Tetap' },
      { id:'peminjaman', icon:'scan-line', label:'Persetujuan' },
      { id:'laporan', icon:'file-bar-chart', label:'Laporan' }
    ],
    kasubag: [...common,
      { id:'persediaan', icon:'package', label:'Persediaan' },
      { id:'sarpras', icon:'building', label:'Sarana Prasarana' },
      { id:'aset', icon:'landmark', label:'Aset Tetap' },
      { id:'peminjaman', icon:'scan-line', label:'Persetujuan' },
      { id:'laporan', icon:'file-bar-chart', label:'Laporan' }
    ],
    admin_persediaan: [...common,
      { id:'persediaan', icon:'package', label:'Kelola Persediaan' },
      { id:'peminjaman', icon:'scan-line', label:'Peminjaman' },
      { id:'laporan', icon:'file-bar-chart', label:'Laporan Persediaan' }
    ],
    admin_sarpras: [...common,
      { id:'sarpras', icon:'building', label:'Kelola Sarpras' },
      { id:'peminjaman', icon:'scan-line', label:'Peminjaman' },
      { id:'laporan', icon:'file-bar-chart', label:'Laporan Sarpras' }
    ],
    admin_aset: [...common,
      { id:'aset', icon:'landmark', label:'Kelola Aset Tetap' },
      { id:'peminjaman', icon:'scan-line', label:'Peminjaman' },
      { id:'laporan', icon:'file-bar-chart', label:'Laporan Aset' }
    ],
    pegawai: [...common,
      { id:'peminjaman', icon:'scan-line', label:'Peminjaman Barang' },
      { id:'riwayat', icon:'history', label:'Riwayat' }
    ]
  };
  return items[role] || common;
}

function renderSidebar() {
  if (!currentUser) return;
  const items = getSidebarItems(currentUser.role);
  const html = items.map(it => `
    <button class="sidebar-item w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-navy-600 ${currentDashSection === it.id ? 'active bg-navy-100 text-navy-800' : ''}" onclick="navigateDash('${it.id}')">
      <i data-lucide="${it.icon}" class="w-4 h-4"></i> ${it.label}
    </button>
  `).join('');
  document.getElementById('sidebar-nav').innerHTML = html;
  document.getElementById('sidebar-nav-mobile').innerHTML = html;
}

function navigateDash(section) {
  currentDashSection = section;
  renderDashboard();
  // Close mobile sidebar
  document.getElementById('sidebar-overlay').classList.add('hidden');
  document.getElementById('sidebar-mobile').classList.add('hidden');
}

// ====================== DASHBOARD RENDERING ======================
function renderDashboard() {
  if (!currentUser) return;
  renderSidebar();
  document.getElementById('topbar-role').textContent = roleLabels[currentUser.role];
  document.getElementById('user-display-name').textContent = currentUser.fullname;
  document.getElementById('user-avatar').textContent = currentUser.fullname.charAt(0).toUpperCase();

  const main = document.getElementById('main-content');
  const label = roleLabels[currentUser.role];
  document.getElementById('topbar-title').textContent = getSidebarItems(currentUser.role).find(i => i.id === currentDashSection)?.label || 'Dashboard';

  switch (currentDashSection) {
    case 'overview': main.innerHTML = renderOverview(); break;
    case 'users': main.innerHTML = renderUsersPage(); break;
    case 'persediaan': main.innerHTML = renderPersediaanPage(); break;
    case 'sarpras': main.innerHTML = renderSarprasPage(); break;
    case 'aset': main.innerHTML = renderAsetPage(); break;
    case 'peminjaman': main.innerHTML = renderPeminjamanPage(); break;
    case 'laporan': main.innerHTML = renderLaporanPage(); break;
    case 'riwayat': main.innerHTML = renderRiwayatPage(); break;
    case 'settings': main.innerHTML = renderSettingsPage(); break;
    default: main.innerHTML = renderOverview();
  }
  lucide.createIcons();
}

function renderOverview() {
  const role = currentUser.role;
  const isAdmin = ['superadmin','kepala','kasubag'].includes(role);
  const greeting = getGreeting();

  let statsCards = '';
  if (role === 'superadmin' || role === 'kepala' || role === 'kasubag') {
    statsCards = `
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        ${statCard('Total Aset BMN','1,248','box','from-navy-500 to-navy-700','+8% dari semester lalu')}
        ${statCard('Persediaan','856','package','from-blue-500 to-blue-700','Stok tersedia')}
        ${statCard('Sarana Prasarana','392','building-2','from-sky-500 to-sky-700','78% kondisi baik')}
        ${statCard('Peminjaman Aktif','156','scan-line','from-emerald-500 to-emerald-700','12 pending')}
      </div>`;
  } else if (role === 'admin_persediaan') {
    statsCards = `
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        ${statCard('Total Persediaan','856','package','from-navy-500 to-navy-700','Dikelola')}
        ${statCard('Stok Rendah','23','alert-triangle','from-amber-500 to-amber-700','Perlu restock')}
        ${statCard('Pengeluaran Bulan Ini','45','trending-down','from-red-500 to-red-700','Unit keluar')}
      </div>`;
  } else if (role === 'admin_sarpras') {
    statsCards = `
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        ${statCard('Total Sarpras','392','building','from-navy-500 to-navy-700','Terdaftar')}
        ${statCard('Kondisi Baik','306','check-circle','from-green-500 to-green-700','78%')}
        ${statCard('Perlu Perbaikan','42','wrench','from-amber-500 to-amber-700','Prioritas')}
      </div>`;
  } else if (role === 'admin_aset') {
    statsCards = `
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        ${statCard('Total Aset Tetap','186','landmark','from-navy-500 to-navy-700','Tercatat')}
        ${statCard('Nilai Aset','Rp 24.5M','trending-up','from-green-500 to-green-700','Total nilai')}
        ${statCard('Penyusutan','Rp 3.2M','trending-down','from-red-500 to-red-700','Tahun ini')}
      </div>`;
  } else {
    statsCards = `
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        ${statCard('Peminjaman Saya','3','scan-line','from-navy-500 to-navy-700','Aktif')}
        ${statCard('Menunggu Approval','1','clock','from-amber-500 to-amber-700','Pending')}
        ${statCard('Total Riwayat','18','history','from-green-500 to-green-700','Selesai')}
      </div>`;
  }

  return `
    <div class="fade-in">
      <div class="bg-gradient-to-r from-navy-700 to-navy-900 rounded-2xl p-6 mb-6 text-white">
        <h2 class="text-xl font-bold mb-1">${greeting}, ${currentUser.fullname.split(' ')[0]}! 👋</h2>
        <p class="text-navy-200 text-sm">Login sebagai <span class="font-semibold text-white">${roleLabels[currentUser.role]}</span> • ${new Date().toLocaleDateString('id-ID',{weekday:'long',year:'numeric',month:'long',day:'numeric'})}</p>
      </div>
      ${statsCards}
      <div class="grid lg:grid-cols-2 gap-6">
        <!-- Recent Activity -->
        <div class="bg-white rounded-2xl border border-navy-100 p-5">
          <h3 class="font-bold text-navy-900 text-sm mb-4 flex items-center gap-2"><i data-lucide="activity" class="w-4 h-4"></i> Aktivitas Terkini</h3>
          <div class="space-y-3">
            ${activityItem('Laptop Lenovo ThinkPad ditambahkan','2 jam lalu','plus-circle','green')}
            ${activityItem('Peminjaman Proyektor disetujui','4 jam lalu','check-circle','blue')}
            ${activityItem('Stok ATK diperbarui (-15 rim)','6 jam lalu','refresh-cw','amber')}
            ${activityItem('Laporan Semester I digenerate','1 hari lalu','file-text','navy')}
            ${activityItem('AC Ruang 3 dijadwalkan perbaikan','2 hari lalu','wrench','red')}
          </div>
        </div>
        <!-- Quick Actions -->
        <div class="bg-white rounded-2xl border border-navy-100 p-5">
          <h3 class="font-bold text-navy-900 text-sm mb-4 flex items-center gap-2"><i data-lucide="zap" class="w-4 h-4"></i> Aksi Cepat</h3>
          <div class="grid grid-cols-2 gap-3">
            ${quickAction('Tambah Barang','plus','navy')}
            ${quickAction('Pinjam Barang','scan-line','blue')}
            ${quickAction('Buat Laporan','file-bar-chart','green')}
            ${quickAction('Cek Stok','search','amber')}
          </div>
          <div class="mt-5 bg-navy-50 rounded-xl p-4">
            <h4 class="font-semibold text-navy-800 text-xs mb-2">Pengumuman</h4>
            <p class="text-xs text-navy-500">Inventarisasi BMN Semester II dijadwalkan tanggal 15-20 Desember 2025. Mohon pastikan semua data aset sudah diperbarui.</p>
          </div>
        </div>
      </div>
    </div>
  `;
}

function statCard(label, value, icon, gradient, sub) {
  return `<div class="bg-gradient-to-br ${gradient} rounded-2xl p-5 text-white">
    <div class="flex items-center justify-between mb-2"><i data-lucide="${icon}" class="w-6 h-6 opacity-80"></i></div>
    <div class="text-2xl font-extrabold">${value}</div>
    <div class="text-xs opacity-80 mt-1">${label}</div>
    <div class="text-[10px] opacity-60 mt-0.5">${sub}</div>
  </div>`;
}

function activityItem(text, time, icon, color) {
  return `<div class="flex items-start gap-3 py-2 border-b border-navy-50 last:border-0">
    <div class="w-8 h-8 rounded-lg bg-${color}-100 flex items-center justify-center flex-shrink-0"><i data-lucide="${icon}" class="w-4 h-4 text-${color}-600"></i></div>
    <div><div class="text-sm text-navy-700">${text}</div><div class="text-xs text-navy-400">${time}</div></div>
  </div>`;
}

function quickAction(label, icon, color) {
  return `<button class="flex flex-col items-center gap-2 p-4 bg-${color}-50 hover:bg-${color}-100 rounded-xl transition">
    <div class="w-10 h-10 rounded-xl bg-${color}-100 flex items-center justify-center"><i data-lucide="${icon}" class="w-5 h-5 text-${color}-600"></i></div>
    <span class="text-xs font-semibold text-${color}-700">${label}</span>
  </button>`;
}

function getGreeting() {
  const h = new Date().getHours();
  if (h < 12) return 'Selamat Pagi';
  if (h < 15) return 'Selamat Siang';
  if (h < 18) return 'Selamat Sore';
  return 'Selamat Malam';
}

// ====================== SUB PAGES ======================
function dataTable(title, headers, rows) {
  return `
    <div class="bg-white rounded-2xl border border-navy-100 overflow-hidden">
      <div class="p-5 border-b border-navy-100 flex items-center justify-between flex-wrap gap-3">
        <h3 class="font-bold text-navy-900">${title}</h3>
        <div class="flex items-center gap-2">
          <div class="relative"><i data-lucide="search" class="w-4 h-4 text-navy-400 absolute left-3 top-1/2 -translate-y-1/2"></i><input type="text" placeholder="Cari..." class="pl-9 pr-4 py-2 bg-navy-50 border border-navy-200 rounded-lg text-sm w-48"></div>
          <button class="btn-primary px-3 py-2 text-white text-sm rounded-lg flex items-center gap-1"><i data-lucide="plus" class="w-4 h-4"></i> Tambah</button>
        </div>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-navy-50 text-navy-600"><tr>${headers.map(h=>`<th class="px-4 py-3 text-left font-semibold text-xs uppercase tracking-wider">${h}</th>`).join('')}<th class="px-4 py-3 text-left font-semibold text-xs uppercase">Aksi</th></tr></thead>
          <tbody class="divide-y divide-navy-50">${rows.map(r => `<tr class="hover:bg-navy-50/50">${r.map(c => `<td class="px-4 py-3 text-navy-700">${c}</td>`).join('')}<td class="px-4 py-3"><div class="flex gap-1"><button class="p-1.5 text-navy-500 hover:bg-navy-100 rounded-lg"><i data-lucide="edit" class="w-3.5 h-3.5"></i></button><button class="p-1.5 text-red-500 hover:bg-red-50 rounded-lg"><i data-lucide="trash-2" class="w-3.5 h-3.5"></i></button></div></td></tr>`).join('')}</tbody>
        </table>
      </div>
      <div class="p-4 border-t border-navy-100 flex items-center justify-between text-xs text-navy-500">
        <span>Menampilkan 1-5 dari ${rows.length} data</span>
        <div class="flex gap-1">
          <button class="px-3 py-1 rounded bg-navy-100 text-navy-600 font-medium">1</button>
          <button class="px-3 py-1 rounded hover:bg-navy-50">2</button>
          <button class="px-3 py-1 rounded hover:bg-navy-50">3</button>
        </div>
      </div>
    </div>`;
}

function badge(text, color) { return `<span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-${color}-100 text-${color}-700">${text}</span>`; }

function renderPersediaanPage() {
  return `<div class="fade-in">${dataTable('Data Persediaan',
    ['No','Kode','Nama Barang','Kategori','Stok','Satuan','Kondisi'],
    [
      ['1','PSD-001','Kertas HVS A4 70gr','ATK','350','Rim',badge('Tersedia','green')],
      ['2','PSD-002','Tinta Printer HP 680','ATK','25','Botol',badge('Stok Rendah','amber')],
      ['3','PSD-003','Map Ordner','ATK','120','Buah',badge('Tersedia','green')],
      ['4','PSD-004','Baterai AA Alkaline','Elektronik','48','Pack',badge('Tersedia','green')],
      ['5','PSD-005','Hand Sanitizer 500ml','Kebersihan','15','Botol',badge('Stok Rendah','amber')]
    ]
  )}</div>`;
}

function renderSarprasPage() {
  return `<div class="fade-in">${dataTable('Data Sarana & Prasarana',
    ['No','Kode','Nama','Lokasi','Kondisi','Tahun','Nilai'],
    [
      ['1','SRP-001','Gedung Utama','Lantai 1-2',badge('Baik','green'),'2015','Rp 8.5M'],
      ['2','SRP-002','Aula Serbaguna','Lantai 1',badge('Baik','green'),'2016','Rp 3.2M'],
      ['3','SRP-003','Ruang Server','Lantai 2',badge('Pemeliharaan','amber'),'2018','Rp 1.8M'],
      ['4','SRP-004','Mushola','Lantai 1',badge('Baik','green'),'2015','Rp 450Jt'],
      ['5','SRP-005','Area Parkir','Halaman',badge('Perbaikan','red'),'2015','Rp 350Jt']
    ]
  )}</div>`;
}

function renderAsetPage() {
  return `<div class="fade-in">${dataTable('Data Aset Tetap',
    ['No','Kode','Nama Aset','Jenis','Tahun','Nilai Perolehan','Kondisi'],
    [
      ['1','AST-001','Tanah Kantor BPMP','Tanah','2005','Rp 5.2M',badge('Baik','green')],
      ['2','AST-002','Gedung Kantor','Bangunan','2015','Rp 8.5M',badge('Baik','green')],
      ['3','AST-003','Toyota Innova BA 1234 GO','Kendaraan','2020','Rp 380Jt',badge('Baik','green')],
      ['4','AST-004','Server Dell PowerEdge','Peralatan','2021','Rp 250Jt',badge('Baik','green')],
      ['5','AST-005','AC Daikin 2PK (12 unit)','Peralatan','2019','Rp 180Jt',badge('Pemeliharaan','amber')]
    ]
  )}</div>`;
}

function renderPeminjamanPage() {
  const isApprover = ['kepala','kasubag','superadmin'].includes(currentUser.role);
  const title = isApprover ? 'Persetujuan Peminjaman' : 'Peminjaman Barang';
  return `<div class="fade-in">${dataTable(title,
    ['No','Pemohon','Barang','Tgl Pinjam','Tgl Kembali','Keperluan','Status'],
    [
      ['1','Hendra Poluakan','Proyektor Epson','01/12/2025','03/12/2025','Presentasi',badge('Pending','amber')],
      ['2','Siti Aminah','Laptop Lenovo','28/11/2025','05/12/2025','Pelatihan',badge('Disetujui','green')],
      ['3','Ahmad Yani','Speaker Portable','02/12/2025','02/12/2025','Upacara',badge('Pending','amber')],
      ['4','Dewi Lestari','Kamera DSLR','25/11/2025','27/11/2025','Dokumentasi',badge('Dikembalikan','blue')],
      ['5','Fadel Mohamad','Minibus','05/12/2025','05/12/2025','Monitoring',badge('Pending','amber')]
    ]
  )}</div>`;
}

function renderLaporanPage() {
  return `<div class="fade-in">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
      ${['Laporan Persediaan Semester II','Laporan Aset Tetap Tahunan','Laporan Sarpras Q4','Laporan Peminjaman Bulanan','Rekap Penyusutan Aset','LBMN Konsolidasi'].map((t,i) => `
        <div class="bg-white rounded-2xl border border-navy-100 p-5 card-hover">
          <div class="w-10 h-10 rounded-xl bg-navy-100 flex items-center justify-center mb-3"><i data-lucide="file-text" class="w-5 h-5 text-navy-600"></i></div>
          <h4 class="font-bold text-navy-900 text-sm mb-1">${t}</h4>
          <p class="text-xs text-navy-500 mb-3">Periode ${i<3?'2025':'Desember 2025'}</p>
          <div class="flex gap-2">
            <button class="text-xs bg-navy-100 hover:bg-navy-200 text-navy-700 font-medium rounded-lg px-3 py-1.5 transition flex items-center gap-1"><i data-lucide="eye" class="w-3 h-3"></i> Lihat</button>
            <button class="text-xs bg-green-100 hover:bg-green-200 text-green-700 font-medium rounded-lg px-3 py-1.5 transition flex items-center gap-1"><i data-lucide="download" class="w-3 h-3"></i> Unduh</button>
          </div>
        </div>
      `).join('')}
    </div>
  </div>`;
}

function renderUsersPage() {
  const allUsers = Object.values(demoAccounts).map((u,i) => [String(i+1), u.fullname, u.nip, roleLabels[u.role], badge('Aktif','green')]);
  return `<div class="fade-in">${dataTable('Manajemen Pengguna',
    ['No','Nama','NIP','Jabatan','Status'],
    allUsers
  )}</div>`;
}

